# DashScope / Qwen runtime
DASHSCOPE_API_KEY=replace-with-your-dashscope-api-key

# App runtime
AGENT_ENV=local
AGENT_DEFAULT_USER_ID=1005
AGENT_DEFAULT_USER_LOCATION=合肥
AGENT_CURRENT_MONTH=2025-09
AGENT_MODEL_PROVIDER=tongyi
AGENT_CHAT_MODEL_NAME=qwen3-max
AGENT_EMBEDDING_MODEL_NAME=text-embedding-v4

# Optional overrides
AGENT_ALLOWED_TOOLS=rag_summarize,get_weather,get_user_location,get_user_id,get_current_month,fetch_external_data,fill_context_for_report
AGENT_TRACE_ENABLED=true
AGENT_API_KEY=dev-api-key
AGENT_DB_PATH=storage/agent.db
AGENT_MEMORY_CONTEXT_TOKENS=6000
AGENT_MEMORY_VECTOR_ENABLED=false
AGENT_MEMORY_VECTOR_PATH=storage/memory_chroma
AGENT_RATE_LIMIT_REQUESTS=60
AGENT_RATE_LIMIT_WINDOW_SECONDS=60

# Optional rerank experiment overrides (production remains disabled by default)
AGENT_CHROMA_CONFIG_PATH=config/chroma.yml
AGENT_RERANK_ENABLED=false
AGENT_RERANK_BACKEND=local
AGENT_RERANK_URL=http://127.0.0.1:8090/rerank
AGENT_RERANK_MODEL=BAAI/bge-reranker-v2-m3
AGENT_RERANK_TIMEOUT_SECONDS=2.0
AGENT_RERANK_FAILURE_THRESHOLD=3
AGENT_RERANK_RECOVERY_SECONDS=30.0
AGENT_RERANK_VERSION=bge-policy-v3
AGENT_RERANK_STRATEGY=shadow
AGENT_RERANK_HYBRID_WEIGHT=0.9
AGENT_RERANK_MODEL_WEIGHT=0.1
AGENT_RERANK_FUSION_K=10
AGENT_RERANK_BYPASS_EXACT_QUERIES=true
AGENT_RERANK_MAX_DOCUMENT_CHARS=1200
AGENT_RERANK_SERVICE_PRELOAD=true
AGENT_RERANK_SERVICE_MAX_DOCUMENT_CHARS=4000

# Multi-instance production backends
AGENT_STORAGE_BACKEND=sqlite
AGENT_APPROVAL_BACKEND=sqlite
AGENT_ARTIFACT_BACKEND=sqlite
AGENT_DATABASE_URL=postgresql://agent:agent@127.0.0.1:5432/agent
AGENT_EVENT_BUS_BACKEND=memory
AGENT_RATE_LIMIT_BACKEND=memory
AGENT_CACHE_BACKEND=memory
AGENT_REDIS_URL=redis://127.0.0.1:6379/0
AGENT_EVENT_REPLAY_SIZE=512
AGENT_EVENT_RETENTION_SECONDS=300

# OpenTelemetry OTLP export
AGENT_OTEL_ENABLED=false
AGENT_OTEL_INSTRUMENT_FASTAPI=true
OTEL_SERVICE_NAME=sweeper-agent
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://127.0.0.1:4318/v1/traces
